{
    "manifest_version": 3,
    "name": "راست نویس",
    "version": "1.1",
    "description": "تغییر جهت متن به راست‌چین و اصلاح فونت",
    "permissions": [
        "contextMenus",
        "activeTab",
        "scripting"
    ],
    "background": {
        "service_worker": "background.js"
    },
    "content_scripts": [
        {
            "matches": [
                "https://gemini.google.com/*",
                "https://chatgpt.com/*",
                "https://claude.ai/*"
            ],
            "js": [
                "content.js"
            ],
            "run_at": "document_end"
        }
    ]
}